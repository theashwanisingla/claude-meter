// Copy this file to secrets.h, fill in your values, and never commit secrets.h.
//
// Choose ONE mode by commenting/uncommenting the relevant block.

// WiFi credentials (required in both modes)
#define WIFI_SSID "your_wifi_name"
#define WIFI_PASS "your_wifi_password"

// ── MODE A: Direct Anthropic API key ─────────────────────────────────────────
// M5Stack calls api.anthropic.com directly. No proxy needed.
// Get your key from https://console.anthropic.com/
// Shows per-minute request and token rate limits.
//
// #define ANTHROPIC_API_KEY "sk-ant-api03-..."

// ── MODE B: Local proxy (claude_proxy.py on your PC) ─────────────────────────
// M5Stack fetches from the proxy running on your PC.
// Shows 5h and 7d Claude Code subscription usage.
// Set SERVER_IP to your PC's local IP address.
//
#define PROXY_URL "http://192.168.29.191:8765/usage"
